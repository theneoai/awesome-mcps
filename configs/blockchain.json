{
  "etherscan": {
    "command": "uvx",
    "args": [
      "mcp-server-etherscan",
      "--api-key", "${ETHERSCAN_API_KEY}"
    ],
    "env": {
      "ETHERSCAN_API_KEY": "your-api-key"
    }
  },
  "alchemy": {
    "command": "uvx",
    "args": [
      "mcp-server-alchemy",
      "--api-key", "${ALCHEMY_API_KEY}"
    ],
    "env": {
      "ALCHEMY_API_KEY": "your-api-key"
    }
  },
  "infura": {
    "command": "uvx",
    "args": [
      "mcp-server-infura",
      "--project-id", "${INFURA_PROJECT_ID}",
      "--project-secret": "${INFURA_PROJECT_SECRET}"
    ],
    "env": {
      "INFURA_PROJECT_ID": "your-project-id",
      "INFURA_PROJECT_SECRET": "your-project-secret"
    }
  }
}