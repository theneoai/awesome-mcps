{
  "shopify-fulfillments": {"command": "uvx", "args": ["mcp-server-shopify-fulfillments", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopify-returns": {"command": "uvx", "args": ["mcp-server-shopify-returns", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopify-refunds": {"command": "uvx", "args": ["mcp-server-shopify-refunds", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "woocommerce-fulfillments": {"command": "uvx", "args": ["mcp-server-woocommerce-fulfillments", "--url", "${WOOCOMMERCE_URL}", "--consumer-key", "${WOOCOMMERCE_CONSUMER_KEY}", "--consumer-secret", "${WOOCOMMERCE_CONSUMER_SECRET}"], "env": {"WOOCOMMERCE_URL": "https://xxx.com", "WOOCOMMERCE_CONSUMER_KEY": "ck_xxx", "WOOCOMMERCE_CONSUMER_SECRET": "cs_xxx"}},
  "bigcommerce-fulfillments": {"command": "uvx", "args": ["mcp-server-bigcommerce-fulfillments", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
  "shipstation-orders": {"command": "uvx", "args": ["mcp-server-shipstation-orders", "--api-key", "${SHIPSTATION_API_KEY}"], "env": {"SHIPSTATION_API_KEY": "xxx"}},
  "shipstation-shipments": {"command": "uvx", "args": ["mcp-server-shipstation-shipments", "--api-key", "${SHIPSTATION_API_KEY}"], "env": {"SHIPSTATION_API_KEY": "xxx"}},
  "easypost-shipments": {"command": "uvx", "args": ["mcp-server-easypost-shipments", "--api-key", "${EASYPOST_API_KEY}"], "env": {"EASYPOST_API_KEY": "xxx"}},
  "shippo-shipments": {"command": "uvx", "args": ["mcp-server-shippo-shipments", "--api-key", "${SHIPPO_API_KEY}"], "env": {"SHIPPO_API_KEY": "xxx"}},
  "fedex-shipments": {"command": "uvx", "args": ["mcp-server-fedex-shipments", "--client-id", "${FEDEX_CLIENT_ID}", "--client-secret", "${FEDEX_CLIENT_SECRET}"], "env": {"FEDEX_CLIENT_ID": "xxx", "FEDEX_CLIENT_SECRET": "xxx"}}
}