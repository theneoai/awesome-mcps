  "activecampaign-campaigns": {"command": "uvx", "args": ["mcp-server-activecampaign-campaigns", "--api-key", "${ACTIVECAMPAIGN_API_KEY}", "--url", "${ACTIVECAMPAIGN_URL}"], "env": {"ACTIVECAMPAIGN_API_KEY": "xxx", "ACTIVECAMPAIGN_URL": "xxx"}},
  "convertkit-forms": {"command": "uvx", "args": ["mcp-server-convertkit-forms", "--api-key", "${CONVERTKIT_API_KEY}"], "env": {"CONVERTKIT_API_KEY": "xxx"}},
