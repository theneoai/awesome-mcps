  "shopify-broadcast": {"command": "uvx", "args": ["mcp-server-shopify-broadcast", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopify-utm": {"command": "uvx", "args": ["mcp-server-shopify-utm", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "klaviyo-campaigns": {"command": "uvx", "args": ["mcp-server-klaviyo-campaigns", "--api-key", "${KLAVIYO_API_KEY}"], "env": {"KLAVIYO_API_KEY": "xxx"}},
  "klaviyo-flows-full": {"command": "uvx", "args": ["mcp-server-klaviyo-flows-full", "--api-key", "${KLAVIYO_API_KEY}"], "env": {"KLAVIYO_API_KEY": "xxx"}},
