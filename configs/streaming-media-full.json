  "vimeo-subscriptions": {"command": "uvx", "args": ["mcp-server-vimeo-subscriptions", "--access-token", "${VIMEO_ACCESS_TOKEN}"], "env": {"VIMEO_ACCESS_TOKEN": "xxx"}}
