  "soundcloud-tracks": {"command": "uvx", "args": ["mcp-server-soundcloud-tracks", "--client-id", "${SOUNDCLOUD_CLIENT_ID}", "--client-secret", "${SOUNDCLOUD_CLIENT_SECRET}"], "env": {"SOUNDCLOUD_CLIENT_ID": "xxx", "SOUNDCLOUD_CLIENT_SECRET": "xxx"}},
  "tidal-tracks": {"command": "uvx", "args": ["mcp-server-tidal-tracks", "--api-token", "${TIDAL_API_TOKEN}"], "env": {"TIDAL_API_TOKEN": "xxx"}},
  "deezer-tracks": {"command": "uvx", "args": ["mcp-server-deezer-tracks", "--api-key", "${DEEZER_API_KEY}"], "env": {"DEEZER_API_KEY": "xxx"}},
