{
  "google-calendar": {"command": "uvx", "args": ["mcp-server-google-calendar", "--api-key", "${GOOGLE_CALENDAR_API_KEY}"], "env": {"GOOGLE_CALENDAR_API_KEY": "xxx"}},
  "google-contacts": {"command": "uvx", "args": ["mcp-server-google-contacts", "--api-key", "${GOOGLE_CONTACTS_API_KEY}"], "env": {"GOOGLE_CONTACTS_API_KEY": "xxx"}},
  "outlook-calendar": {"command": "uvx", "args": ["mcp-server-outlook-calendar", "--client-id", "${OUTLOOK_CLIENT_ID}", "--client-secret", "${OUTLOOK_CLIENT_SECRET}"], "env": {"OUTLOOK_CLIENT_ID": "xxx", "OUTLOOK_CLIENT_SECRET": "xxx"}},
  "outlook-contacts": {"command": "uvx", "args": ["mcp-server-outlook-contacts", "--client-id", "${OUTLOOK_CLIENT_ID}", "--client-secret", "${OUTLOOK_CLIENT_SECRET}"], "env": {"OUTLOOK_CLIENT_ID": "xxx", "OUTLOOK_CLIENT_SECRET": "xxx"}},
  "apple-calendar": {"command": "uvx", "args": ["mcp-server-apple-calendar", "--api-key", "${APPLE_CALENDAR_API_KEY}"], "env": {"APPLE_CALENDAR_API_KEY": "xxx"}},
  "apple-contacts": {"command": "uvx", "args": ["mcp-server-apple-contacts", "--api-key", "${APPLE_CONTACTS_API_KEY}"], "env": {"APPLE_CONTACTS_API_KEY": "xxx"}},
  "caldav-calendars": {"command": "uvx", "args": ["mcp-server-caldav-calendars", "--url", "${CALDAV_URL}", "--username", "${CALDAV_USERNAME}", "--password", "${CALDAV_PASSWORD}"], "env": {"CALDAV_URL": "https://caldav.example.com", "CALDAV_USERNAME": "xxx", "CALDAV_PASSWORD": "xxx"}},
  "carddav-contacts": {"command": "uvx", "args": ["mcp-server-carddav-contacts", "--url", "${CARDDAV_URL}", "--username", "${CARDDAV_USERNAME}", "--password", "${CARDDAV_PASSWORD}"], "env": {"CARDDAV_URL": "https://carddav.example.com", "CARDDAV_USERNAME": "xxx", "CARDDAV_PASSWORD": "xxx"}},
  "zoom-calendar": {"command": "uvx", "args": ["mcp-server-zoom-calendar", "--api-key", "${ZOOM_API_KEY}", "--api-secret", "${ZOOM_API_SECRET}"], "env": {"ZOOM_API_KEY": "xxx", "ZOOM_API_SECRET": "xxx"}},
  "teams-calendar": {"command": "uvx", "args": ["mcp-server-teams-calendar", "--client-id", "${TEAMS_CLIENT_ID}", "--client-secret", "${TEAMS_CLIENT_SECRET}"], "env": {"TEAMS_CLIENT_ID": "xxx", "TEAMS_CLIENT_SECRET": "xxx"}}
}