{
  "vault-secrets": {"command": "uvx", "args": ["mcp-server-vault-secrets", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-engines": {"command": "uvx", "args": ["mcp-server-vault-engines", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-policies": {"command": "uvx", "args": ["mcp-server-vault-policies", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-aws-secrets": {"command": "uvx", "args": ["mcp-server-vault-aws-secrets", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-databases": {"command": "uvx", "args": ["mcp-server-vault-databases", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "consul-services": {"command": "uvx", "args": ["mcp-server-consul-services", "--url", "${CONSUL_URL}"], "env": {"CONSUL_URL": "http://localhost:8500"}},
  "consul-nodes": {"command": "uvx", "args": ["mcp-server-consul-nodes", "--url", "${CONSUL_URL}"], "env": {"CONSUL_URL": "http://localhost:8500"}},
  "consul-kv": {"command": "uvx", "args": ["mcp-server-consul-kv", "--url", "${CONSUL_URL}"], "env": {"CONSUL_URL": "http://localhost:8500"}},
  "consul-agents": {"command": "uvx", "args": ["mcp-server-consul-agents", "--url", "${CONSUL_URL}"], "env": {"CONSUL_URL": "http://localhost:8500"}},
  "aws-secrets-manager": {"command": "uvx", "args": ["mcp-server-aws-secrets-manager", "--access-key-id", "${AWS_ACCESS_KEY_ID}", "--secret-access-key", "${AWS_SECRET_ACCESS_KEY}"], "env": {"AWS_ACCESS_KEY_ID": "xxx", "AWS_SECRET_ACCESS_KEY": "xxx"}}
}