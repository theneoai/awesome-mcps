{
  "timescalecloud-databases": {"command": "uvx", "args": ["mcp-server-timescalecloud-databases", "--api-key", "${TIMESCALECLOUD_API_KEY}"], "env": {"TIMESCALECLOUD_API_KEY": "xxx"}},
  "planetscale-databases": {"command": "uvx", "args": ["mcp-server-planetscale-databases", "--api-token", "${PLANETSCALE_API_TOKEN}"], "env": {"PLANETSCALE_API_TOKEN": "xxx"}},
  "planetscale-branches": {"command": "uvx", "args": ["mcp-server-planetscale-branches", "--api-token", "${PLANETSCALE_API_TOKEN}"], "env": {"PLANETSCALE_API_TOKEN": "xxx"}},
  "ternder-databases": {"command": "uvx", "args": ["mcp-server-ternder-databases", "--api-key", "${TERNDER_API_KEY}"], "env": {"TERNDER_API_KEY": "xxx"}},
  "neon-projects": {"command": "uvx", "args": ["mcp-server-neon-projects", "--api-key", "${NEON_API_KEY}"], "env": {"NEON_API_KEY": "xxx"}},
  "convex-databases": {"command": "uvx", "args": ["mcp-server-convex-databases", "--api-key", "${CONVEX_API_KEY}"], "env": {"CONVEX_API_KEY": "xxx"}},
