{
  "zabbix-triggers": {"command": "uvx", "args": ["mcp-server-zabbix-triggers", "--url", "${ZABBIX_URL}", "--username", "${ZABBIX_USERNAME}", "--password", "${ZABBIX_PASSWORD}"], "env": {"ZABBIX_URL": "http://localhost:8080", "ZABBIX_USERNAME": "Admin", "ZABBIX_PASSWORD": "xxx"}},
  "zabbix-hosts": {"command": "uvx", "args": ["mcp-server-zabbix-hosts", "--url", "${ZABBIX_URL}", "--username", "${ZABBIX_USERNAME}", "--password", "${ZABBIX_PASSWORD}"], "env": {"ZABBIX_URL": "http://localhost:8080", "ZABBIX_USERNAME": "Admin", "ZABBIX_PASSWORD": "xxx"}},
  "grafana-alerts": {"command": "uvx", "args": ["mcp-server-grafana-alerts", "--url", "${GRAFANA_URL}", "--token", "${GRAFANA_TOKEN}"], "env": {"GRAFANA_URL": "http://localhost:3000", "GRAFANA_TOKEN": "xxx"}},
  "grafana-dashboards": {"command": "uvx", "args": ["mcp-server-grafana-dashboards", "--url", "${GRAFANA_URL}", "--token", "${GRAFANA_TOKEN}"], "env": {"GRAFANA_URL": "http://localhost:3000", "GRAFANA_TOKEN": "xxx"}},
  "kibana-search": {"command": "uvx", "args": ["mcp-server-kibana-search", "--url", "${KIBANA_URL}", "--username", "${KIBANA_USERNAME}", "--password", "${KIBANA_PASSWORD}"], "env": {"KIBANA_URL": "http://localhost:5601", "KIBANA_USERNAME": "elastic", "KIBANA_PASSWORD": "xxx"}},
  "kibana-visualizations": {"command": "uvx", "args": ["mcp-server-kibana-visualizations", "--url", "${KIBANA_URL}", "--username", "${KIBANA_USERNAME}", "--password", "${KIBANA_PASSWORD}"], "env": {"KIBANA_URL": "http://localhost:5601", "KIBANA_USERNAME": "elastic", "KIBANA_PASSWORD": "xxx"}},
  "kibana-dashboards": {"command": "uvx", "args": ["mcp-server-kibana-dashboards", "--url", "${KIBANA_URL}", "--username", "${KIBANA_USERNAME}", "--password", "${KIBANA_PASSWORD}"], "env": {"KIBANA_URL": "http://localhost:5601", "KIBANA_USERNAME": "elastic", "KIBANA_PASSWORD": "xxx"}},
  "splunk-search": {"command": "uvx", "args": ["mcp-server-splunk-search", "--url", "${SPLUNK_URL}", "--username", "${SPLUNK_USERNAME}", "--password", "${SPLUNK_PASSWORD}"], "env": {"SPLUNK_URL": "https://localhost:8089", "SPLUNK_USERNAME": "admin", "SPLUNK_PASSWORD": "xxx"}},
  "sumologic-search": {"command": "uvx", "args": ["mcp-server-sumologic-search", "--access-id", "${SUMOLOGIC_ACCESS_ID}", "--access-key", "${SUMOLOGIC_ACCESS_KEY}"], "env": {"SUMOLOGIC_ACCESS_ID": "xxx", "SUMOLOGIC_ACCESS_KEY": "xxx"}},
  "elk-search": {"command": "uvx", "args": ["mcp-server-elk-search", "--url", "${ELASTICSEARCH_URL}", "--username", "${ELASTICSEARCH_USERNAME}", "--password", "${ELASTICSEARCH_PASSWORD}"], "env": {"ELASTICSEARCH_URL": "http://localhost:9200", "ELASTICSEARCH_USERNAME": "elastic", "ELASTICSEARCH_PASSWORD": "xxx"}}
}