{
  "cassandra": {
    "command": "uvx",
    "args": ["mcp-server-cassandra", "--host", "${CASSANDRA_HOST}", "--port", "${CASSANDRA_PORT}"],
    "env": {"CASSANDRA_HOST": "localhost", "CASSANDRA_PORT": "9042", "CASSANDRA_USERNAME": "cassandra", "CASSANDRA_PASSWORD": "cassandra"}
  },
  "elasticsearch": {
    "command": "uvx",
    "args": ["mcp-server-elasticsearch", "--url", "${ELASTICSEARCH_URL}"],
    "env": {"ELASTICSEARCH_URL": "http://localhost:9200", "ELASTICSEARCH_USERNAME": "elastic", "ELASTICSEARCH_PASSWORD": "password"}
  },
  "opensearch": {
    "command": "uvx",
    "args": ["mcp-server-opensearch", "--url", "${OPENSEARCH_URL}"],
    "env": {"OPENSEARCH_URL": "http://localhost:9200", "OPENSEARCH_USERNAME": "admin", "OPENSEARCH_PASSWORD": "admin"}
  },
  "solr": {
    "command": "uvx",
    "args": ["mcp-server-solr", "--url", "${SOLR_URL}"],
    "env": {"SOLR_URL": "http://localhost:8983"}
  },
  "meilisearch": {
    "command": "uvx",
    "args": ["mcp-server-meilisearch", "--host", "${MEILI_HOST}", "--api-key", "${MEILI_API_KEY}"],
    "env": {"MEILI_HOST": "http://localhost:7700", "MEILI_API_KEY": "masterKey"}
  },
  "typesense": {
    "command": "uvx",
    "args": ["mcp-server-typesense", "--host", "${TYPESENSE_HOST}", "--api-key", "${TYPESENSE_API_KEY}"],
    "env": {"TYPESENSE_HOST": "http://localhost:8108", "TYPESENSE_API_KEY": "xyz"}
  },
  "qdrant": {
    "command": "uvx",
    "args": ["mcp-server-qdrant", "--url", "${QDRANT_URL}", "--api-key", "${QDRANT_API_KEY}"],
    "env": {"QDRANT_URL": "http://localhost:6333", "QDRANT_API_KEY": "xxx"}
  },
  "weaviate": {
    "command": "uvx",
    "args": ["mcp-server-weaviate", "--url", "${WEAVIATE_URL}", "--api-key", "${WEAVIATE_API_KEY}"],
    "env": {"WEAVIATE_URL": "http://localhost:8080", "WEAVIATE_API_KEY": "xxx"}
  },
  "pinecone": {
    "command": "uvx",
    "args": ["mcp-server-pinecone", "--api-key", "${PINECONE_API_KEY}", "--environment", "${PINECONE_ENV}"],
    "env": {"PINECONE_API_KEY": "xxx", "PINECONE_ENV": "us-east-1"}
  },
  "milvus": {
    "command": "uvx",
    "args": ["mcp-server-milvus", "--host", "${MILVUS_HOST}", "--port", "${MILVUS_PORT}"],
    "env": {"MILVUS_HOST": "localhost", "MILVUS_PORT": "19530"}
  }
}