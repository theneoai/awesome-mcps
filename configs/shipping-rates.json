{
  "shopify-shipping": {"command": "uvx", "args": ["mcp-server-shopify-shipping", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopify-shipping-rates": {"command": "uvx", "args": ["mcp-server-shopify-shipping-rates", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopify-carriers": {"command": "uvx", "args": ["mcp-server-shopify-carriers", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "woocommerce-shipping": {"command": "uvx", "args": ["mcp-server-woocommerce-shipping", "--url", "${WOOCOMMERCE_URL}", "--consumer-key", "${WOOCOMMERCE_CONSUMER_KEY}", "--consumer-secret", "${WOOCOMMERCE_CONSUMER_SECRET}"], "env": {"WOOCOMMERCE_URL": "https://xxx.com", "WOOCOMMERCE_CONSUMER_KEY": "ck_xxx", "WOOCOMMERCE_CONSUMER_SECRET": "cs_xxx"}},
  "bigcommerce-shipping": {"command": "uvx", "args": ["mcp-server-bigcommerce-shipping", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
  "fedex-rates": {"command": "uvx", "args": ["mcp-server-fedex-rates", "--client-id", "${FEDEX_CLIENT_ID}", "--client-secret", "${FEDEX_CLIENT_SECRET}"], "env": {"FEDEX_CLIENT_ID": "xxx", "FEDEX_CLIENT_SECRET": "xxx"}},
  "ups-rates": {"command": "uvx", "args": ["mcp-server-ups-rates", "--client-id", "${UPS_CLIENT_ID}", "--client-secret", "${UPS_CLIENT_SECRET}"], "env": {"UPS_CLIENT_ID": "xxx", "UPS_CLIENT_SECRET": "xxx"}},
  "dhl-rates": {"command": "uvx", "args": ["mcp-server-dhl-rates", "--api-key", "${DHL_API_KEY}"], "env": {"DHL_API_KEY": "xxx"}},
  "usps-rates": {"command": "uvx", "args": ["mcp-server-usps-rates", "--api-key", "${USPS_API_KEY}"], "env": {"USPS_API_KEY": "xxx"}},
  "shipstation-rates": {"command": "uvx", "args": ["mcp-server-shipstation-rates", "--api-key", "${SHIPSTATION_API_KEY}"], "env": {"SHIPSTATION_API_KEY": "xxx"}}
}