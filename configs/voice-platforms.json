{
  "twilio-voice": {"command": "uvx", "args": ["mcp-server-twilio-voice", "--account-sid", "${TWILIO_ACCOUNT_SID}", "--auth-token", "${TWILIO_AUTH_TOKEN}"], "env": {"TWILIO_ACCOUNT_SID": "xxx", "TWILIO_AUTH_TOKEN": "xxx"}},
  "twilio-messaging": {"command": "uvx", "args": ["mcp-server-twilio-messaging", "--account-sid", "${TWILIO_ACCOUNT_SID}", "--auth-token", "${TWILIO_AUTH_TOKEN}"], "env": {"TWILIO_ACCOUNT_SID": "xxx", "TWILIO_AUTH_TOKEN": "xxx"}},
  "twilio-whatsapp": {"command": "uvx", "args": ["mcp-server-twilio-whatsapp", "--account-sid", "${TWILIO_ACCOUNT_SID}", "--auth-token", "${TWILIO_AUTH_TOKEN}"], "env": {"TWILIO_ACCOUNT_SID": "xxx", "TWILIO_AUTH_TOKEN": "xxx"}},
  "nexmo-voice": {"command": "uvx", "args": ["mcp-server-nexmo-voice", "--api-key", "${NEXMO_API_KEY}", "--api-secret", "${NEXMO_API_SECRET}"], "env": {"NEXMO_API_KEY": "xxx", "NEXMO_API_SECRET": "xxx"}},
  "plivo-voice": {"command": "uvx", "args": ["mcp-server-plivo-voice", "--auth-id", "${PLIVO_AUTH_ID}", "--auth-token", "${PLIVO_AUTH_TOKEN}"], "env": {"PLIVO_AUTH_ID": "xxx", "PLIVO_AUTH_TOKEN": "xxx"}},
  "bandwidth-voice": {"command": "uvx", "args": ["mcp-server-bandwidth-voice", "--username", "${BANDWIDTH_USERNAME}", "--password", "${BANDWIDTH_PASSWORD}", "--account-id", "${BANDWIDTH_ACCOUNT_ID}"], "env": {"BANDWIDTH_USERNAME": "xxx", "BANDWIDTH_PASSWORD": "xxx", "BANDWIDTH_ACCOUNT_ID": "xxx"}},
  "telnyx-voice": {"command": "uvx", "args": ["mcp-server-telnyx-voice", "--api-key", "${TELNYX_API_KEY}"], "env": {"TELNYX_API_KEY": "xxx"}},
  "vonage-voice": {"command": "uvx", "args": ["mcp-server-vonage-voice", "--api-key", "${VONAGE_API_KEY}", "--api-secret", "${VONAGE_API_SECRET}"], "env": {"VONAGE_API_KEY": "xxx", "VONAGE_API_SECRET": "xxx"}},
  "aws-connect": {"command": "uvx", "args": ["mcp-server-aws-connect", "--profile", "${AWS_PROFILE}"], "env": {"AWS_PROFILE": "default"}},
  "genesys": {"command": "uvx", "args": ["mcp-server-genesys", "--api-key", "${GENESYS_API_KEY}"], "env": {"GENESYS_API_KEY": "xxx"}}
}