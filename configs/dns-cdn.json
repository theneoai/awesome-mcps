  "cloudflare-zones": {"command": "uvx", "args": ["mcp-server-cloudflare-zones", "--api-key", "${CF_API_KEY}", "--email", "${CF_EMAIL}"], "env": {"CF_API_KEY": "xxx", "CF_EMAIL": "xxx@xxx.com"}},
