  "route53-traffic-policies": {"command": "uvx", "args": ["mcp-server-route53-traffic-policies", "--access-key-id", "${AWS_ACCESS_KEY_ID}", "--secret-access-key", "${AWS_SECRET_ACCESS_KEY}"], "env": {"AWS_ACCESS_KEY_ID": "xxx", "AWS_SECRET_ACCESS_KEY": "xxx"}},
  "dnsimple-domains": {"command": "uvx", "args": ["mcp-server-dnsimple-domains", "--api-key", "${DNSIMPLE_API_KEY}"], "env": {"DNSIMPLE_API_KEY": "xxx"}},
