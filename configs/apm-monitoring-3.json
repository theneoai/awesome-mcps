{
  "appdynamics-dashboards": {"command": "uvx", "args": ["mcp-server-appdynamics-dashboards", "--controller-url", "${APPDYNAMICS_CONTROLLER_URL}", "--api-key", "${APPDYNAMICS_API_KEY}"], "env": {"APPDYNAMICS_CONTROLLER_URL": "https://xxx.saas.appdynamics.com", "APPDYNAMICS_API_KEY": "xxx"}},
  "appdynamics-metrics": {"command": "uvx", "args": ["mcp-server-appdynamics-metrics", "--controller-url", "${APPDYNAMICS_CONTROLLER_URL}", "--api-key", "${APPDYNAMICS_API_KEY}"], "env": {"APPDYNAMICS_CONTROLLER_URL": "https://xxx.saas.appdynamics.com", "APPDYNAMICS_API_KEY": "xxx"}},
  "dynatrace-problems": {"command": "uvx", "args": ["mcp-server-dynatrace-problems", "--api-url", "${DYNATRACE_API_URL}", "--api-token", "${DYNATRACE_API_TOKEN}"], "env": {"DYNATRACE_API_URL": "https://xxx.dynatrace.com", "DYNATRACE_API_TOKEN": "xxx"}},
  "dynatrace-metrics": {"command": "uvx", "args": ["mcp-server-dynatrace-metrics", "--api-url", "${DYNATRACE_API_URL}", "--api-token", "${DYNATRACE_API_TOKEN}"], "env": {"DYNATRACE_API_URL": "https://xxx.dynatrace.com", "DYNATRACE_API_TOKEN": "xxx"}},
  "dynatrace-hosts": {"command": "uvx", "args": ["mcp-server-dynatrace-hosts", "--api-url", "${DYNATRACE_API_URL}", "--api-token", "${DYNATRACE_API_TOKEN}"], "env": {"DYNATRACE_API_URL": "https://xxx.dynatrace.com", "DYNATRACE_API_TOKEN": "xxx"}},
  "elastic-apm": {"command": "uvx", "args": ["mcp-server-elastic-apm", "--url", "${ES_APM_URL}", "--username", "${ES_APM_USERNAME}", "--password", "${ES_APM_PASSWORD}"], "env": {"ES_APM_URL": "http://localhost:8200", "ES_APM_USERNAME": "elastic", "ES_APM_PASSWORD": "xxx"}},
  "instana-traces": {"command": "uvx", "args": ["mcp-server-instana-traces", "--api-key", "${INSTANA_API_KEY}"], "env": {"INSTANA_API_KEY": "xxx", "INSTANA_ENDPOINT": "https://xxx.instana.io"}},
  "instana-metrics": {"command": "uvx", "args": ["mcp-server-instana-metrics", "--api-key", "${INSTANA_API_KEY}"], "env": {"INSTANA_API_KEY": "xxx", "INSTANA_ENDPOINT": "https://xxx.instana.io"}},
  "honeycomb-datasets": {"command": "uvx", "args": ["mcp-server-honeycomb-datasets", "--api-key", "${HONEYCOMB_API_KEY}"], "env": {"HONEYCOMB_API_KEY": "xxx"}},
  "honeycomb-traces": {"command": "uvx", "args": ["mcp-server-honeycomb-traces", "--api-key", "${HONEYCOMB_API_KEY}"], "env": {"HONEYCOMB_API_KEY": "xxx"}}
