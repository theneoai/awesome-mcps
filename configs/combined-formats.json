{
  "shopify-combined-formats": {"command": "uvx", "args": ["mcp-server-shopify-combined-formats", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "woocommerce-combined-formats": {"command": "uvx", "args": ["mcp-server-woocommerce-combined-formats", "--url", "${WOOCOMMERCE_URL}", "--consumer-key", "${WOOCOMMERCE_CONSUMER_KEY}", "--consumer-secret", "${WOOCOMMERCE_CONSUMER_SECRET}"], "env": {"WOOCOMMERCE_URL": "https://xxx.com", "WOOCOMMERCE_CONSUMER_KEY": "ck_xxx", "WOOCOMMERCE_CONSUMER_SECRET": "cs_xxx"}},
  "stripe-combined-formats": {"command": "uvx", "args": ["mcp-server-stripe-combined-formats", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "square-combined-formats": {"command": "uvx", "args": ["mcp-server-square-combined-formats", "--access-token", "${SQUARE_ACCESS_TOKEN}"], "env": {"SQUARE_ACCESS_TOKEN": "xxx"}},
  "braintree-combined-formats": {"command": "uvx", "args": ["mcp-server-braintree-combined-formats", "--environment", "${BT_ENVIRONMENT}", "--merchant-id", "${BT_MERCHANT_ID}", "--public-key", "${BT_PUBLIC_KEY}", "--private-key", "${BT_PRIVATE_KEY}"], "env": {"BT_ENVIRONMENT": "sandbox", "BT_MERCHANT_ID": "xxx", "BT_PUBLIC_KEY": "xxx", "BT_PRIVATE_KEY": "xxx"}},
  "adyen-combined-formats": {"command": "uvx", "args": ["mcp-server-adyen-combined-formats", "--api-key", "${ADYEN_API_KEY}", "--merchant-account", "${ADYEN_MERCHANT_ACCOUNT}"], "env": {"ADYEN_API_KEY": "xxx", "ADYEN_MERCHANT_ACCOUNT": "xxx"}},
  "paypal-combined-formats": {"command": "uvx", "args": ["mcp-server-paypal-combined-formats", "--client-id", "${PAYPAL_CLIENT_ID}", "--client-secret", "${PAYPAL_CLIENT_SECRET}"], "env": {"PAYPAL_CLIENT_ID": "xxx", "PAYPAL_CLIENT_SECRET": "xxx"}},
  "razorpay-combined-formats": {"command": "uvx", "args": ["mcp-server-razorpay-combined-formats", "--key-id", "${RAZORPAY_KEY_ID}", "--key-secret", "${RAZORPAY_KEY_SECRET}"], "env": {"RAZORPAY_KEY_ID": "xxx", "RAZORPAY_KEY_SECRET": "xxx"}},
  "bigcommerce-combined-formats": {"command": "uvx", "args": ["mcp-server-bigcommerce-combined-formats", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
  "magento-combined-formats": {"command": "uvx", "args": ["mcp-server-magento-combined-formats", "--url", "${MAGENTO_URL}"], "env": {"MAGENTO_URL": "https://xxx.com", "MAGENTO_USERNAME": "xxx", "MAGENTO_PASSWORD": "xxx"}}
}