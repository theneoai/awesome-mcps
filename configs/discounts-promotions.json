{
  "stripe-coupons": {"command": "uvx", "args": ["mcp-server-stripe-coupons", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-discounts": {"command": "uvx", "args": ["mcp-server-stripe-discounts", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-promotions": {"command": "uvx", "args": ["mcp-server-stripe-promotions", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "shopify-discounts": {"command": "uvx", "args": ["mcp-server-shopify-discounts", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "woocommerce-discounts": {"command": "uvx", "args": ["mcp-server-woocommerce-discounts", "--url", "${WOOCOMMERCE_URL}", "--consumer-key", "${WOOCOMMERCE_CONSUMER_KEY}", "--consumer-secret", "${WOOCOMMERCE_CONSUMER_SECRET}"], "env": {"WOOCOMMERCE_URL": "https://xxx.com", "WOOCOMMERCE_CONSUMER_KEY": "ck_xxx", "WOOCOMMERCE_CONSUMER_SECRET": "cs_xxx"}},
  "bigcommerce-discounts": {"command": "uvx", "args": ["mcp-server-bigcommerce-discounts", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
  "magento-discounts": {"command": "uvx", "args": ["mcp-server-magento-discounts", "--url", "${MAGENTO_URL}"], "env": {"MAGENTO_URL": "https://xxx.com", "MAGENTO_USERNAME": "xxx", "MAGENTO_PASSWORD": "xxx"}},
  "chargebee-coupons": {"command": "uvx", "args": ["mcp-server-chargebee-coupons", "--api-key", "${CHARGEBEE_API_KEY}", "--site", "${CHARGEBEE_SITE}"], "env": {"CHARGEBEE_API_KEY": "xxx", "CHARGEBEE_SITE": "xxx"}},
  "paddle-discounts": {"command": "uvx", "args": ["mcp-server-paddle-discounts", "--vendor-id", "${PADDLE_VENDOR_ID}", "--api-key", "${PADDLE_API_KEY}"], "env": {"PADDLE_VENDOR_ID": "xxx", "PADDLE_API_KEY": "xxx"}},
  "gumroad-discounts": {"command": "uvx", "args": ["mcp-server-gumroad-discounts", "--api-key", "${GUMROAD_API_KEY}"], "env": {"GUMROAD_API_KEY": "xxx"}}
}