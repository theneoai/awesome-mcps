    "args": ["mcp-server-ticketmaster", "--api-key", "${TICKETMASTER_API_KEY}"],
    "env": {"TICKETMASTER_API_KEY": "xxx"}
  },
  "stubhub": {
    "command": "uvx",
    "args": ["mcp-server-stubhub", "--api-key", "${STUBHUB_API_KEY}"],
    "env": {"STUBHUB_API_KEY": "xxx"}
  },
  "eventbrite": {
    "command": "uvx",
