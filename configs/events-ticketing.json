{
  "spotify-bands": {
    "command": "uvx",
    "args": ["mcp-server-spotify-bands", "--client-id", "${SPOTIFY_CLIENT_ID}", "--client-secret", "${SPOTIFY_CLIENT_SECRET}"],
    "env": {"SPOTIFY_CLIENT_ID": "xxx", "SPOTIFY_CLIENT_SECRET": "xxx"}
  },
  "songkick": {
    "command": "uvx",
    "args": ["mcp-server-songkick", "--api-key", "${SONGKICK_API_KEY}"],
    "env": {"SONGKICK_API_KEY": "xxx"}
  },
  "seatgeek": {
    "command": "uvx",
    "args": ["mcp-server-seatgeek", "--client-id", "${SEATGEEK_CLIENT_ID}", "--client-secret", "${SEATGEEK_CLIENT_SECRET}"],
    "env": {"SEATGEEK_CLIENT_ID": "xxx", "SEATGEEK_CLIENT_SECRET": "xxx"}
