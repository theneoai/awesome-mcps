{
  "shopify-gift-cards": {"command": "uvx", "args": ["mcp-server-shopify-gift-cards", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "shopifyloyalty": {"command": "uvx", "args": ["mcp-server-shopify-loyalty", "--shop", "${SHOPIFY_SHOP}", "--token", "${SHOPIFY_ACCESS_TOKEN}"], "env": {"SHOPIFY_SHOP": "xxx.myshopify.com", "SHOPIFY_ACCESS_TOKEN": "xxx"}},
  "bigcommerce-gift-cards": {"command": "uvx", "args": ["mcp-server-bigcommerce-gift-cards", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
  "woocommerce-gift-cards": {"command": "uvx", "args": ["mcp-server-woocommerce-gift-cards", "--url", "${WOOCOMMERCE_URL}", "--consumer-key", "${WOOCOMMERCE_CONSUMER_KEY}", "--consumer-secret", "${WOOCOMMERCE_CONSUMER_SECRET}"], "env": {"WOOCOMMERCE_URL": "https://xxx.com", "WOOCOMMERCE_CONSUMER_KEY": "ck_xxx", "WOOCOMMERCE_CONSUMER_SECRET": "cs_xxx"}},
  "smile-io": {"command": "uvx", "args": ["mcp-server-smile-io", "--api-key", "${SMILE_IO_API_KEY}"], "env": {"SMILE_IO_API_KEY": "xxx"}},
  "rewards-fuel": {"command": "uvx", "args": ["mcp-server-rewards-fuel", "--api-key", "${REWARDS_FUEL_API_KEY}"], "env": {"REWARDS_FUEL_API_KEY": "xxx"}},
  "loyaltyLion": {"command": "uvx", "args": ["mcp-server-loyalty-lion", "--api-key", "${LOYALTY_LION_API_KEY}"], "env": {"LOYALTY_LION_API_KEY": "xxx"}},
  "xango": {"command": "uvx", "args": ["mcp-server-xango", "--api-key", "${XANGO_API_KEY}"], "env": {"XANGO_API_KEY": "xxx"}},
  "referralcandy": {"command": "uvx", "args": ["mcp-server-referralcandy", "--api-key", "${REFERRALCANDY_API_KEY}"], "env": {"REFERRALCANDY_API_KEY": "xxx"}},
  "friendbuy": {"command": "uvx", "args": ["mcp-server-friendbuy", "--api-key", "${FRIENDBUY_API_KEY}"], "env": {"FRIENDBUY_API_KEY": "xxx"}}
}