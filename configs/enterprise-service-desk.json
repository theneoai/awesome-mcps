  "dynamics-tickets": {"command": "uvx", "args": ["mcp-server-dynamics-tickets", "--url", "${DYNAMICS_URL}", "--api-key", "${DYNAMICS_API_KEY}"], "env": {"DYNAMICS_URL": "https://xxx.crm.dynamics.com", "DYNAMICS_API_KEY": "xxx"}},
