  "servicenow-incidents": {"command": "uvx", "args": ["mcp-server-servicenow-incidents", "--url", "${SERVICENOW_URL}", "--username", "${SERVICENOW_USERNAME}", "--password", "${SERVICENOW_PASSWORD}"], "env": {"SERVICENOW_URL": "https://xxx.service-now.com", "SERVICENOW_USERNAME": "admin", "SERVICENOW_PASSWORD": "xxx"}},
  "servicenow-tasks": {"command": "uvx", "args": ["mcp-server-servicenow-tasks", "--url", "${SERVICENOW_URL}", "--username", "${SERVICENOW_USERNAME}", "--password", "${SERVICENOW_PASSWORD}"], "env": {"SERVICENOW_URL": "https://xxx.service-now.com", "SERVICENOW_USERNAME": "admin", "SERVICENOW_PASSWORD": "xxx"}},
