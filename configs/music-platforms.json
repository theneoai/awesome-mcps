{
  "spotify-player": {"command": "uvx", "args": ["mcp-server-spotify-player", "--client-id", "${SPOTIFY_CLIENT_ID}", "--client-secret", "${SPOTIFY_CLIENT_SECRET}"], "env": {"SPOTIFY_CLIENT_ID": "xxx", "SPOTIFY_CLIENT_SECRET": "xxx"}},
  "spotify-browse": {"command": "uvx", "args": ["mcp-server-spotify-browse", "--client-id", "${SPOTIFY_CLIENT_ID}", "--client-secret", "${SPOTIFY_CLIENT_SECRET}"], "env": {"SPOTIFY_CLIENT_ID": "xxx", "SPOTIFY_CLIENT_SECRET": "xxx"}},
  "spotify-playlists": {"command": "uvx", "args": ["mcp-server-spotify-playlists", "--client-id", "${SPOTIFY_CLIENT_ID}", "--client-secret", "${SPOTIFY_CLIENT_SECRET}"], "env": {"SPOTIFY_CLIENT_ID": "xxx", "SPOTIFY_CLIENT_SECRET": "xxx"}},
  "apple-music-api": {"command": "uvx", "args": ["mcp-server-apple-music-api", "--key-id", "${APPLE_MUSIC_KEY_ID}", "--team-id", "${APPLE_MUSIC_TEAM_ID}", "--music-kit-token", "${APPLE_MUSIC_KIT_TOKEN}"], "env": {"APPLE_MUSIC_KEY_ID": "xxx", "APPLE_MUSIC_TEAM_ID": "xxx", "APPLE_MUSIC_KIT_TOKEN": "xxx"}},
  "soundcloud-api": {"command": "uvx", "args": ["mcp-server-soundcloud-api", "--client-id", "${SOUNDCLOUD_CLIENT_ID}", "--client-secret", "${SOUNDCLOUD_CLIENT_SECRET}"], "env": {"SOUNDCLOUD_CLIENT_ID": "xxx", "SOUNDCLOUD_CLIENT_SECRET": "xxx"}},
  "tidal-api": {"command": "uvx", "args": ["mcp-server-tidal-api", "--api-token", "${TIDAL_API_TOKEN}"], "env": {"TIDAL_API_TOKEN": "xxx"}},
  "deezer-api": {"command": "uvx", "args": ["mcp-server-deezer-api", "--api-key", "${DEEZER_API_KEY}"], "env": {"DEEZER_API_KEY": "xxx"}},
  "pandora": {"command": "uvx", "args": ["mcp-server-pandora", "--api-key", "${PANDORA_API_KEY}"], "env": {"PANDORA_API_KEY": "xxx"}},
  "iheartradio": {"command": "uvx", "args": ["mcp-server-iheartradio", "--api-key", "${IHEARTRADIO_API_KEY}"], "env": {"IHEARTRADIO_API_KEY": "xxx"}}
}