{
  "vault-secrets": {"command": "uvx", "args": ["mcp-server-vault-secrets", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-kv": {"command": "uvx", "args": ["mcp-server-vault-kv", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-pki": {"command": "uvx", "args": ["mcp-server-vault-pki", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-aws": {"command": "uvx", "args": ["mcp-server-vault-aws", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "vault-database": {"command": "uvx", "args": ["mcp-server-vault-database", "--url", "${VAULT_URL}", "--token", "${VAULT_TOKEN}"], "env": {"VAULT_URL": "http://localhost:8200", "VAULT_TOKEN": "xxx"}},
  "aws-secrets-manager-secrets": {"command": "uvx", "args": ["mcp-server-aws-secrets-manager-secrets", "--profile", "${AWS_PROFILE}"], "env": {"AWS_PROFILE": "default"}},
  "gcp-secret-manager-secrets": {"command": "uvx", "args": ["mcp-server-gcp-secret-manager-secrets", "--credentials-path", "${GCP_CREDENTIALS_PATH}"], "env": {"GCP_CREDENTIALS_PATH": "/path/to/credentials.json"}},
  "azure-keyvault-secrets": {"command": "uvx", "args": ["mcp-server-azure-keyvault-secrets", "--vault-url", "${KEYVAULT_URL}", "--client-id", "${AZURE_CLIENT_ID}", "--client-secret", "${AZURE_CLIENT_SECRET}"], "env": {"KEYVAULT_URL": "https://vault.vault.azure.net", "AZURE_CLIENT_ID": "xxx", "AZURE_CLIENT_SECRET": "xxx"}},
  "hashicorp-consul-kv": {"command": "uvx", "args": ["mcp-server-consul-kv", "--host", "${CONSUL_HOST}", "--port", "${CONSUL_PORT}"], "env": {"CONSUL_HOST": "localhost", "CONSUL_PORT": "8500"}},
  "spring-cloud-config": {"command": "uvx", "args": ["mcp-server-spring-cloud-config", "--url", "${SPRING_CONFIG_URL}"], "env": {"SPRING_CONFIG_URL": "http://localhost:8888"}}
}