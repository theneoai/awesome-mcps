{
  "datadog-monitors-mgmt": {"command": "uvx", "args": ["mcp-server-datadog-monitors-mgmt", "--api-key", "${DD_API_KEY}", "--app-key", "${DD_APP_KEY}"], "env": {"DD_API_KEY": "xxx", "DD_APP_KEY": "xxx"}},
  "datadog-downtimes": {"command": "uvx", "args": ["mcp-server-datadog-downtimes", "--api-key", "${DD_API_KEY}"], "env": {"DD_API_KEY": "xxx"}},
  "pagerduty-schedules": {"command": "uvx", "args": ["mcp-server-pagerduty-schedules", "--api-key", "${PAGERDUTY_API_KEY}"], "env": {"PAGERDUTY_API_KEY": "xxx"}},
  "pagerduty-oncalls": {"command": "uvx", "args": ["mcp-server-pagerduty-oncalls", "--api-key", "${PAGERDUTY_API_KEY}"], "env": {"PAGERDUTY_API_KEY": "xxx"}},
  "pagerduty-incidents": {"command": "uvx", "args": ["mcp-server-pagerduty-incidents", "--api-key", "${PAGERDUTY_API_KEY}"], "env": {"PAGERDUTY_API_KEY": "xxx"}},
  "opsgenie-alerts": {"command": "uvx", "args": ["mcp-server-opsgenie-alerts", "--api-key", "${OPSGENIE_API_KEY}"], "env": {"OPSGENIE_API_KEY": "xxx"}},
  "victoriametrics-alerts": {"command": "uvx", "args": ["mcp-server-victoriametrics-alerts", "--url", "${VM_URL}"], "env": {"VM_URL": "http://localhost:8428"}},
  "grafana-alerts": {"command": "uvx", "args": ["mcp-server-grafana-alerts", "--host", "${GRAFANA_HOST}", "--token", "${GRAFANA_TOKEN}"], "env": {"GRAFANA_HOST": "http://localhost:3000", "GRAFANA_TOKEN": "xxx"}},
  "sentry-alerts": {"command": "uvx", "args": ["mcp-server-sentry-alerts", "--auth-token", "${SENTRY_AUTH_TOKEN}", "--organization", "${SENTRY_ORG}"], "env": {"SENTRY_AUTH_TOKEN": "xxx", "SENTRY_ORG": "org"}},
  "newrelic-alerts-mgmt": {"command": "uvx", "args": ["mcp-server-newrelic-alerts-mgmt", "--api-key", "${NEWRELIC_API_KEY}"], "env": {"NEWRELIC_API_KEY": "xxx"}}
}