  "recurring-billing-razorpay": {"command": "uvx", "args": ["mcp-server-recurring-razorpay", "--key-id", "${RAZORPAY_KEY_ID}", "--key-secret", "${RAZORPAY_KEY_SECRET}"], "env": {"RAZORPAY_KEY_ID": "xxx", "RAZORPAY_KEY_SECRET": "xxx"}}
