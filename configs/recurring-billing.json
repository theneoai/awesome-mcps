  "chargebee-invoices": {"command": "uvx", "args": ["mcp-server-chargebee-invoices", "--api-key", "${CHARGEBEE_API_KEY}", "--site", "${CHARGEBEE_SITE}"], "env": {"CHARGEBEE_API_KEY": "xxx", "CHARGEBEE_SITE": "xxx"}},
  "paddle-subscriptions": {"command": "uvx", "args": ["mcp-server-paddle-subscriptions", "--vendor-id", "${PADDLE_VENDOR_ID}", "--api-key", "${PADDLE_API_KEY}"], "env": {"PADDLE_VENDOR_ID": "xxx", "PADDLE_API_KEY": "xxx"}},
