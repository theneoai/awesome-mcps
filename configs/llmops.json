  "agentops": {"command": "uvx", "args": ["mcp-server-agentops", "--api-key", "${AGENTOPS_API_KEY}"], "env": {"AGENTOPS_API_KEY": "xxx"}},
  "braintrust": {"command": "uvx", "args": ["mcp-server-braintrust", "--api-key", "${BRAINTRUST_API_KEY}"], "env": {"BRAINTRUST_API_KEY": "xxx"}},
  "evals": {"command": "uvx", "args": ["mcp-server-evals", "--api-key", "${EVALS_API_KEY}"], "env": {"EVALS_API_KEY": "xxx"}},
