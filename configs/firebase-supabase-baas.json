  "supabase-realtime": {"command": "uvx", "args": ["mcp-server-supabase-realtime", "--url", "${SUPABASE_URL}", "--anon-key", "${SUPABASE_ANON_KEY}"], "env": {"SUPABASE_URL": "https://xxx.supabase.co", "SUPABASE_ANON_KEY": "xxx"}},
