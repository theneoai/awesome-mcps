{
  "google-search": {
    "command": "uvx",
    "args": [
      "mcp-server-google-search",
      "--api-key", "${GOOGLE_SEARCH_API_KEY}",
      "--cx", "${GOOGLE_SEARCH_CX}"
    ],
    "env": {
      "GOOGLE_SEARCH_API_KEY": "your-api-key",
      "GOOGLE_SEARCH_CX": "your-search-engine-id"
    }
  },
  "duckduckgo": {
    "command": "uvx",
    "args": [
      "mcp-server-duckduckgo"
    ],
    "env": {}
  },
  "bing": {
    "command": "uvx",
    "args": [
      "mcp-server-bing",
      "--api-key", "${BING_API_KEY}"
    ],
    "env": {
      "BING_API_KEY": "your-api-key"
    }
  }
}