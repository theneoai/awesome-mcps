{
  "stripe-balance": {"command": "uvx", "args": ["mcp-server-stripe-balance", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-charges": {"command": "uvx", "args": ["mcp-server-stripe-charges", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-refunds": {"command": "uvx", "args": ["mcp-server-stripe-refunds", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-disputes": {"command": "uvx", "args": ["mcp-server-stripe-disputes", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-transfers": {"command": "uvx", "args": ["mcp-server-stripe-transfers", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "stripe-payouts": {"command": "uvx", "args": ["mcp-server-stripe-payouts", "--api-key", "${STRIPE_API_KEY}"], "env": {"STRIPE_API_KEY": "sk_xxx"}},
  "braintree-transactions": {"command": "uvx", "args": ["mcp-server-braintree-transactions", "--environment", "${BT_ENVIRONMENT}", "--merchant-id", "${BT_MERCHANT_ID}", "--public-key", "${BT_PUBLIC_KEY}", "--private-key", "${BT_PRIVATE_KEY}"], "env": {"BT_ENVIRONMENT": "sandbox", "BT_MERCHANT_ID": "xxx", "BT_PUBLIC_KEY": "xxx", "BT_PRIVATE_KEY": "xxx"}},
  "adyen-transactions": {"command": "uvx", "args": ["mcp-server-adyen-transactions", "--api-key", "${ADYEN_API_KEY}", "--merchant-account", "${ADYEN_MERCHANT_ACCOUNT}"], "env": {"ADYEN_API_KEY": "xxx", "ADYEN_MERCHANT_ACCOUNT": "xxx"}},
  "square-transactions": {"command": "uvx", "args": ["mcp-server-square-transactions", "--access-token", "${SQUARE_ACCESS_TOKEN}"], "env": {"SQUARE_ACCESS_TOKEN": "xxx"}},
  "paypal-transactions": {"command": "uvx", "args": ["mcp-server-paypal-transactions", "--client-id", "${PAYPAL_CLIENT_ID}", "--client-secret", "${PAYPAL_CLIENT_SECRET}"], "env": {"PAYPAL_CLIENT_ID": "xxx", "PAYPAL_CLIENT_SECRET": "xxx"}}
}