  "bigcommerce-products": {"command": "uvx", "args": ["mcp-server-bigcommerce-products", "--store-hash", "${BC_STORE_HASH}", "--access-token", "${BC_ACCESS_TOKEN}"], "env": {"BC_STORE_HASH": "xxx", "BC_ACCESS_TOKEN": "xxx"}},
